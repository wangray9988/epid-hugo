{
  "name": "EPID 每日多语种SEO文章",
  "nodes": [
    {
      "id": "1",
      "name": "每天定时",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": "1.2",
      "position": [0, 400],
      "parameters": {
        "rule": { "interval": [{ "field": "cronExpression", "expression": "0 9 * * *" }] }
      }
    },
    {
      "id": "2",
      "name": "配置",
      "type": "n8n-nodes-base.set",
      "typeVersion": "3.4",
      "position": [240, 400],
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "a", "name": "repo_owner", "type": "string", "value": "YOUR_GITHUB_USER" },
            { "id": "b", "name": "repo_name", "type": "string", "value": "epid-hugo" },
            { "id": "c", "name": "branch", "type": "string", "value": "main" },
            { "id": "d", "name": "slug", "type": "string", "value": "weichai-wp10-turbo-maintenance" },
            { "id": "e", "name": "topic", "type": "string", "value": "Weichai WP10 turbocharger maintenance guide for diesel generators and trucks" }
          ]
        }
      }
    },
    {
      "id": "3",
      "name": "生成英文文章",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": "4.2",
      "position": [480, 400],
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": { "parameters": [
          { "name": "Authorization", "value": "Bearer {{$env.OPENAI_API_KEY}}" },
          { "name": "Content-Type", "value": "application/json" }
        ] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"model\":\"gpt-4o-mini\",\"messages\":[{\"role\":\"system\",\"content\":\"You are an SEO copywriter for EPID, a Chinese exporter of diesel engine parts (Weichai, Baudouin, Yuchai, Cummins, Deutz, Caterpillar). Write original, helpful, non-spammy articles. Use correct technical terms and part numbers. Never invent part numbers.\"},{\"role\":\"user\",\"content\":\"Write a 600-900 word SEO article in English about: {{$('配置').item.json.topic}}. Use Markdown with one H1 and several H2 sections. Include a compatibility/part-number note and end with a CTA to WhatsApp +86 18137139988 and email sales@epidengineparts.com. Return ONLY valid Markdown, no code fences.\"}],\"temperature\":0.7}",
        "options": {}
      }
    },
    {
      "id": "4",
      "name": "提取英文MD",
      "type": "n8n-nodes-base.code",
      "typeVersion": "2",
      "position": [720, 400],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const md = $input.item.json.choices[0].message.content.trim();\nreturn [{ json: { en_md: md } }];"
      }
    },
    {
      "id": "5",
      "name": "翻译-西语",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": "4.2",
      "position": [960, 200],
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": { "parameters": [
          { "name": "Authorization", "value": "Bearer {{$env.OPENAI_API_KEY}}" },
          { "name": "Content-Type", "value": "application/json" }
        ] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"model\":\"gpt-4o-mini\",\"messages\":[{\"role\":\"system\",\"content\":\"Translate the following Markdown article into Spanish. Keep the Markdown structure, headings, and all brand names / part numbers unchanged. Return ONLY Markdown.\"},{\"role\":\"user\",\"content\":\"{{$('提取英文MD').item.json.en_md}}\"}],\"temperature\":0.3}",
        "options": {}
      }
    },
    {
      "id": "6",
      "name": "翻译-阿语",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": "4.2",
