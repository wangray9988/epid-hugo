        "jsonBody": "{\"model\":\"gpt-4o-mini\",\"messages\":[{\"role\":\"system\",\"content\":\"Translate the following Markdown article into Arabic. Keep the Markdown structure and all brand names / part numbers unchanged. Return ONLY Markdown.\"},{\"role\":\"user\",\"content\":\"{{$('提取英文MD').item.json.en_md}}\"}],\"temperature\":0.3}",
        "options": {}
      }
    },
