    {
      "id": "9",
      "name": "组装并提交",
      "type": "n8n-nodes-base.code",
      "typeVersion": "2",
      "position": [1200, 400],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const cfg = $('配置').item.json;\nconst b64 = s => Buffer.from(s, 'utf8').toString('base64');\nconst slug = cfg.slug;\nreturn [{ json: {\n  en_b64: b64($('提取英文MD').item.json.en_md),\n  es_b64: b64($('翻译-西语').item.json.choices[0].message.content.trim()),\n  ar_b64: b64($('翻译-阿语').item.json.choices[0].message.content.trim()),\n  fr_b64: b64($('翻译-法语').item.json.choices[0].message.content.trim()),\n  de_b64: b64($('翻译-德语').item.json.choices[0].message.content.trim()),\n  en_path: `content/news/${slug}.md`,\n  es_path: `content/es/news/${slug}.md`,\n  ar_path: `content/ar/news/${slug}.md`,\n  fr_path: `content/fr/news/${slug}.md`,\n  de_path: `content/de/news/${slug}.md`\n} }];"
      }
    },
